{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus instance scraping the openai-worker-node /metrics endpoint",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Operator-facing dashboard for the openai-worker-node. Mirrors the metric catalog in docs/design-docs/metrics.md.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Overview",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "id": 1,
      "title": "Build version",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 0, "y": 1, "w": 5, "h": 4},
      "targets": [
        {
          "expr": "livepeer_worker_build_info{job=~\"$job\"}",
          "legendFormat": "{{version}} / {{protocol_version}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "name",
        "graphMode": "none",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue"}]}
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Uptime",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 5, "y": 1, "w": 5, "h": 4},
      "targets": [
        {
          "expr": "livepeer_worker_uptime_seconds{job=~\"$job\"}",
          "legendFormat": "uptime",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value",
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 60}, {"color": "green", "value": 600}]}
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Request qps",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 10, "y": 1, "w": 4, "h": 4},
      "targets": [
        {
          "expr": "sum(rate(livepeer_worker_requests_total{job=~\"$job\"}[1m]))",
          "legendFormat": "qps",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value",
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue"}]}
        },
        "overrides": []
      }
    },
    {
      "type": "gauge",
      "id": 4,
      "title": "Error rate (5m)",
      "description": "Fraction of customer-facing requests with outcome 4xx, 402, or 5xx over the past 5 min. Green <1%, yellow 1-5%, red >=5%.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 14, "y": 1, "w": 5, "h": 4},
      "targets": [
        {
          "expr": "sum(rate(livepeer_worker_requests_total{job=~\"$job\",outcome=~\"4xx|402|5xx\"}[5m])) / clamp_min(sum(rate(livepeer_worker_requests_total{job=~\"$job\"}[5m])), 1e-9)",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.01}, {"color": "red", "value": 0.05}]}
        },
        "overrides": []
      }
    },
    {
      "type": "gauge",
      "id": 5,
      "title": "Concurrency utilization",
      "description": "inflight / max_concurrent. Yellow >=70%, red >=90%.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 19, "y": 1, "w": 5, "h": 4},
      "targets": [
        {
          "expr": "livepeer_worker_inflight_requests{job=~\"$job\"} / clamp_min(livepeer_worker_max_concurrent{job=~\"$job\"}, 1)",
          "legendFormat": "utilization",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.7}, {"color": "red", "value": 0.9}]}
        },
        "overrides": []
      }
    },

    {
      "type": "row",
      "id": 200,
      "title": "Request lifecycle",
      "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 6,
      "title": "qps by capability + outcome",
      "description": "Customer-facing request rate, stacked by capability and outcome.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (capability, outcome) (rate(livepeer_worker_requests_total{job=~\"$job\"}[5m]))",
          "legendFormat": "{{capability}} / {{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "stacking": {"mode": "normal"}}
        },
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": ".*/ 5xx"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]},
          {"matcher": {"id": "byRegexp", "options": ".*/ 402"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]}
        ]
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "type": "timeseries",
      "id": 7,
      "title": "p99 latency by capability",
      "description": "End-to-end request latency, p99, grouped by capability.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, capability) (rate(livepeer_worker_request_duration_seconds_bucket{job=~\"$job\"}[5m])))",
          "legendFormat": "p99 {{capability}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 0}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "type": "table",
      "id": 8,
      "title": "p50/p95/p99 by capability+model (worst 10)",
      "description": "Latest p50, p95, p99 latency per (capability, model). Sorted by p99 desc.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 0, "y": 14, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.50, sum by (le, capability, model) (rate(livepeer_worker_request_duration_seconds_bucket{job=~\"$job\"}[5m]))))",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "refId": "A"
        },
        {
          "expr": "topk(10, histogram_quantile(0.95, sum by (le, capability, model) (rate(livepeer_worker_request_duration_seconds_bucket{job=~\"$job\"}[5m]))))",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "refId": "B"
        },
        {
          "expr": "topk(10, histogram_quantile(0.99, sum by (le, capability, model) (rate(livepeer_worker_request_duration_seconds_bucket{job=~\"$job\"}[5m]))))",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "refId": "C"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true},
            "renameByName": {
              "Value #A": "p50",
              "Value #B": "p95",
              "Value #C": "p99"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s", "decimals": 4, "custom": {"align": "left"}},
        "overrides": []
      },
      "options": {"showHeader": true, "footer": {"show": false}, "sortBy": [{"displayName": "p99", "desc": true}]}
    },
    {
      "type": "timeseries",
      "id": 9,
      "title": "Capacity rejections",
      "description": "503s emitted because the inflight semaphore was full. Painted red.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 12, "y": 14, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (capability) (rate(livepeer_worker_capacity_rejections_total{job=~\"$job\"}[5m]))",
          "legendFormat": "{{capability}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {"mode": "fixed", "fixedColor": "red"},
          "custom": {"drawStyle": "bars", "fillOpacity": 70, "stacking": {"mode": "normal"}, "lineWidth": 2}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["sum", "max"]}, "tooltip": {"mode": "multi"}}
    },

    {
      "type": "row",
      "id": 300,
      "title": "Work units (the revenue signal)",
      "gridPos": {"x": 0, "y": 22, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 10,
      "title": "Work units billed by capability",
      "description": "Per-second rate of work units billed. The bridge joins this against revenue for margin reconciliation.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 0, "y": 23, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (capability) (rate(livepeer_worker_work_units_total{job=~\"$job\"}[5m]))",
          "legendFormat": "{{capability}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "stacking": {"mode": "normal"}}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "type": "table",
      "id": 11,
      "title": "Work units by capability + unit",
      "description": "Current per-minute rate and total since dashboard window start. Split by unit so different metering dimensions are visible side-by-side.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 12, "y": 23, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (capability, unit) (rate(livepeer_worker_work_units_total{job=~\"$job\"}[1m])) * 60",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "refId": "A"
        },
        {
          "expr": "sum by (capability, unit) (increase(livepeer_worker_work_units_total{job=~\"$job\"}[$__range]))",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "refId": "B"
        }
      ],
      "transformations": [
        {"id": "merge", "options": {}},
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true},
            "renameByName": {
              "Value #A": "rate (per min)",
              "Value #B": "total (range)"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 2, "custom": {"align": "left"}},
        "overrides": []
      },
      "options": {"showHeader": true, "footer": {"show": false}, "sortBy": [{"displayName": "rate (per min)", "desc": true}]}
    },
    {
      "type": "table",
      "id": 12,
      "title": "Top 10 (capability, model) by work-units rate (1h)",
      "description": "Which (capability, model) pairs are doing the most billable work right now.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 0, "y": 31, "w": 24, "h": 8},
      "targets": [
        {
          "expr": "topk(10, sum by (capability, model) (rate(livepeer_worker_work_units_total{job=~\"$job\"}[1h])))",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 4, "custom": {"align": "left"}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Value"}, "properties": [{"id": "displayName", "value": "rate (1h, units/sec)"}]}
        ]
      },
      "options": {"showHeader": true, "footer": {"show": false}, "sortBy": [{"displayName": "rate (1h, units/sec)", "desc": true}]}
    },

    {
      "type": "row",
      "id": 400,
      "title": "Backend health (upstream model providers)",
      "gridPos": {"x": 0, "y": 39, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 13,
      "title": "Backend qps by capability + outcome",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 0, "y": 40, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (capability, outcome) (rate(livepeer_worker_backend_requests_total{job=~\"$job\"}[5m]))",
          "legendFormat": "{{capability}} / {{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "stacking": {"mode": "normal"}}
        },
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": ".*/ error"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]},
          {"matcher": {"id": "byRegexp", "options": ".*/ ok"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]}
        ]
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "type": "timeseries",
      "id": 14,
      "title": "Backend p99 by capability + model",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 12, "y": 40, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, capability, model) (rate(livepeer_worker_backend_request_duration_seconds_bucket{job=~\"$job\"}[5m])))",
          "legendFormat": "p99 {{capability}}/{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 0}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["max"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "type": "timeseries",
      "id": 15,
      "title": "Backend errors by error_class",
      "description": "error_class ∈ {timeout, 5xx, malformed, connect}. Stacked.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 0, "y": 48, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (error_class) (rate(livepeer_worker_backend_errors_total{job=~\"$job\"}[5m]))",
          "legendFormat": "{{error_class}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 30, "stacking": {"mode": "normal"}}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "timeout"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]},
          {"matcher": {"id": "byName", "options": "5xx"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]},
          {"matcher": {"id": "byName", "options": "connect"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "purple"}}]},
          {"matcher": {"id": "byName", "options": "malformed"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}]}
        ]
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["sum", "max"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "type": "table",
      "id": 16,
      "title": "Time since last successful backend response",
      "description": "Per (capability, model). Red when staleness >=300s; alert on this.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 12, "y": 48, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "(time() - livepeer_worker_backend_last_success_timestamp_seconds{job=~\"$job\"})",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true},
            "renameByName": {
              "Value": "staleness"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 1,
          "custom": {"align": "left"},
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 60}, {"color": "red", "value": 300}]}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "staleness"}, "properties": [{"id": "custom.cellOptions", "value": {"type": "color-background"}}]}
        ]
      },
      "options": {"showHeader": true, "footer": {"show": false}, "sortBy": [{"displayName": "staleness", "desc": true}]}
    },

    {
      "type": "row",
      "id": 500,
      "title": "Daemon RPC (unix-socket fast path)",
      "gridPos": {"x": 0, "y": 56, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 17,
      "title": "Daemon RPC qps by method + outcome",
      "description": "method ∈ {ProcessPayment, DebitBalance, GetQuote, ListCapabilities}; outcome ∈ {ok, error}.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 0, "y": 57, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (method, outcome) (rate(livepeer_worker_daemon_rpc_calls_total{job=~\"$job\"}[5m]))",
          "legendFormat": "{{method}} / {{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "stacking": {"mode": "normal"}}
        },
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": ".*/ error"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]}
        ]
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "type": "stat",
      "id": 18,
      "title": "Daemon RPC error rate (5m)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 12, "y": 57, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(livepeer_worker_daemon_rpc_calls_total{job=~\"$job\",outcome=\"error\"}[5m])) / clamp_min(sum(rate(livepeer_worker_daemon_rpc_calls_total{job=~\"$job\"}[5m])), 1e-9)",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value",
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {"mode": "thresholds"},
