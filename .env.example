# Copy to .env and fill the required values. compose.prod.yaml reads
# this automatically. See docs/operations/running-with-docker.md for
# the full walkthrough.

# --- Image tags ---
PAYMENT_IMAGE_TAG=v3.0.0
WORKER_IMAGE_TAG=v3.0.0

# --- Required ---
# Read-write JSON-RPC endpoint. The receiver-mode daemon needs write
# access to submit ticket-redemption transactions.
CHAIN_RPC=REQUIRED-https://arb1.arbitrum.io/rpc-or-your-provider

# Separate config files in the v3 deployment model.
WORKER_CONFIG_PATH=./worker.yaml
PAYMENT_DAEMON_CONFIG_PATH=./payment-daemon.yaml

# Keystore material for the daemon's signer wallet.
PAYMENT_KEYSTORE_PATH=./keystore.json
PAYMENT_KEYSTORE_PASSWORD_PATH=./keystore-password

# --- Optional hot/cold split ---
# If set, the daemon advertises this cold orch address as the ticket
# recipient while the hot wallet in PAYMENT_KEYSTORE_PATH signs
# redemptions. Leave commented to use recipient_eth_address from
# payment-daemon.yaml directly.
# ORCH_ADDRESS=0xYourColdOrchAddress

# --- Optional wallet preflight ---
# MIN_BALANCE_WEI=5000000000000000

# --- Host exposure ---
WORKER_HOST_PORT=8080

# --- Logging ---
PAYMENT_LOG_LEVEL=info
PAYMENT_LOG_FORMAT=json
WORKER_LOG_LEVEL=info

# --- Metrics (empty/unset = off) ---
# PAYMENT_METRICS_PORT=9092
# WORKER_METRICS_PORT=9093
